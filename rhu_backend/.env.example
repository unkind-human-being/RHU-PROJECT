PORT=5000
MONGO_URI=your_mongodb_connection_string_here
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
JWT_ISSUER=rhu-mobile-portal
JWT_AUDIENCE=rhu-android-app
NODE_ENV=development
ALLOWED_ORIGINS=*

SEED_ADMIN_NAME=IPHO System Administrator
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=your_admin_password_here
RESET_SEED_ADMIN_PASSWORD=false

AGORA_APP_ID=your_agora_app_id_here
AGORA_APP_CERTIFICATE=your_agora_app_certificate_here
AGORA_TOKEN_EXPIRE_SECONDS=3600

CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here
CLOUDINARY_APPOINTMENT_FOLDER=rhu/appointment-photos

APPOINTMENT_COOLDOWN_HOURS=5